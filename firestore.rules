rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all (Must be the first rule block)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email_verified == true &&
             request.auth.token.email.matches('(?i)gabrieljrussell@gmail\\.com');
    }

    function isValidMediaOverride(data) {
      return (data.get('video', '') is string && data.get('video', '').size() <= 2000)
             && (data.get('photo', '') is string && data.get('photo', '').size() <= 2000)
             && (data.get('geology', '') is string && data.get('geology', '').size() <= 2000)
             && (data.get('pump', '') is string && data.get('pump', '').size() <= 2000)
             && (data.get('background', '') is string && data.get('background', '').size() <= 2000);
    }

    // Media overrides path setup
    match /media_overrides/{suburbSlug} {
      allow read: if true; // Publicly accessible so anyone viewing the site gets matching visuals
      
      allow create: if isValidId(suburbSlug) && 
                       isValidMediaOverride(request.resource.data) && 
                       isAdmin();
                       
      allow update: if isValidMediaOverride(request.resource.data) && 
                       isAdmin() && 
                       isValidId(suburbSlug);
                       
      allow delete: if isAdmin() && 
                       isValidId(suburbSlug);
    }

    function isValidLead(data) {
      return (data.fullName is string && data.fullName.size() <= 200)
             && (data.phone is string && data.phone.size() <= 50)
             && (data.get('email', '') is string && data.get('email', '').size() <= 200)
             && (data.suburb is string && data.suburb.size() <= 205)
             && (data.get('serviceType', '') is string && data.get('serviceType', '').size() <= 200)
             && (data.get('notes', '') is string && data.get('notes', '').size() <= 2000)
             && (data.get('urgency', '') is string && data.get('urgency', '').size() <= 50)
             && (data.get('ticketId', '') is string && data.get('ticketId', '').size() <= 100);
    }

    // Customer Leads submissions
    match /leads/{leadId} {
      allow read, update, delete: if isAdmin() && isValidId(leadId);
      allow create: if isValidId(leadId) && isValidLead(request.resource.data);
    }
  }
}
